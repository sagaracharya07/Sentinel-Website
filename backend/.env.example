# Sentinel AI — mailbox connection settings
# Copy this file to `.env` (same folder) and fill in your REAL values there.
# `.env` itself must never be committed or shared — it holds a real password.
#
# ---------------------------------------------------------------------------
# GMAIL SETUP (recommended for testing — use a throwaway/test Gmail account,
# not your primary one, while you're getting this working):
#   1. Turn on 2-Step Verification on the Google account:
#      https://myaccount.google.com/security
#   2. Create an App Password:
#      https://myaccount.google.com/apppasswords
#      (choose "Mail" as the app) -- Google gives you a 16-character code.
#   3. Use that 16-character code as MAILBOX_PASSWORD below, NOT your real
#      Google account password.
#   4. MAILBOX_HOST=imap.gmail.com, MAILBOX_PORT=993
#
# OUTLOOK / OFFICE365 SETUP:
#   MAILBOX_HOST=outlook.office365.com, MAILBOX_PORT=993
#   Outlook also requires an app password if 2FA is on:
#   https://account.live.com/proofs/AppPassword
#
# YAHOO SETUP:
#   MAILBOX_HOST=imap.mail.yahoo.com, MAILBOX_PORT=993
#   Also requires an app password: https://login.yahoo.com/account/security
# ---------------------------------------------------------------------------

MAILBOX_HOST=imap.gmail.com
MAILBOX_PORT=993
MAILBOX_USERNAME=your-test-account@gmail.com
MAILBOX_PASSWORD=your-16-char-app-password
MAILBOX_INBOX_FOLDER=INBOX
MAILBOX_QUARANTINE_FOLDER=Sentinel-Quarantine
MAILBOX_USE_SSL=true

# How often the background poller checks for new mail, in seconds.
# 30-60s is reasonable for a demo; real gateways would use IMAP IDLE
# (push notifications) instead of polling -- noted as a future upgrade.
MAILBOX_POLL_SECONDS=45

# Flask session secret -- change this for any real deployment.
SENTINEL_SECRET_KEY=dev-secret-change-in-production
