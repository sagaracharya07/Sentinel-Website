# Sentinel AI — mailbox connection settings
# Copy this file to `.env` (same folder) and fill in your REAL values there.
# `.env` itself must never be committed or shared — it holds a real password.
#
# ---------------------------------------------------------------------------
# GMAIL SETUP (recommended for testing — use a throwaway/test Gmail account,
# not your primary one, while you're getting this working):
#   1. Turn on 2-Step Verification on the Google account:
#      https://myaccount.google.com/security
#   2. Create an App Password:
#      https://myaccount.google.com/apppasswords
#      (choose "Mail" as the app) -- Google gives you a 16-character code.
#   3. Use that 16-character code as MAILBOX_PASSWORD below, NOT your real
#      Google account password.
#   4. MAILBOX_HOST=imap.gmail.com, MAILBOX_PORT=993
#
# OUTLOOK / OFFICE365 SETUP:
#   MAILBOX_HOST=outlook.office365.com, MAILBOX_PORT=993
#   Outlook also requires an app password if 2FA is on:
#   https://account.live.com/proofs/AppPassword
#
# YAHOO SETUP:
#   MAILBOX_HOST=imap.mail.yahoo.com, MAILBOX_PORT=993
#   Also requires an app password: https://login.yahoo.com/account/security
# ---------------------------------------------------------------------------

MAILBOX_HOST=imap.gmail.com
MAILBOX_PORT=993
MAILBOX_USERNAME=your-test-account@gmail.com
MAILBOX_PASSWORD=your-16-char-app-password
MAILBOX_INBOX_FOLDER=INBOX
MAILBOX_QUARANTINE_FOLDER=Sentinel-Quarantine
# No MAILBOX_USE_SSL setting: this app only ever connects over IMAP-over-SSL
# (port 993). There is no plaintext-IMAP option to configure.

# How often the background poller checks for new mail, in seconds.
# 30-60s is reasonable for a demo; real gateways would use IMAP IDLE
# (push notifications) instead of polling -- noted as a future upgrade.
MAILBOX_POLL_SECONDS=45

# Flask session secret -- change this for any real deployment.
SENTINEL_SECRET_KEY=dev-secret-change-in-production

# ---------------------------------------------------------------------------
# GMAIL OAUTH (primary integration) -- connect a Gmail mailbox from the
# website instead of storing an IMAP app password. Full step-by-step setup
# is in docs/GMAIL_SETUP.md. Summary:
#   1. Create a Google Cloud project and ENABLE the Gmail API.
#   2. Configure the OAuth consent screen (Testing mode + add your test
#      users is enough for a demo; production needs Google verification).
#   3. Create an OAuth *Web application* client -> Client ID + Secret below.
#   4. Add the redirect URI EXACTLY as GOOGLE_OAUTH_REDIRECT_URI below to
#      that client's "Authorized redirect URIs".
# These three are read by integrations/gmail/oauth.py; if any is unset, the
# Connect Gmail button is disabled and the rest of the app runs normally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/admin/gmail/callback

# Encryption key for Gmail refresh tokens AT REST (crypto.py). REQUIRED
# before a mailbox can be connected. Generate one with:
#     python crypto.py generate-key
# Deliberately separate from SENTINEL_SECRET_KEY: rotating the session
# secret must never make stored mailbox tokens undecryptable.
TOKEN_ENCRYPTION_KEY=

# Automatic-monitoring settings (used from Checkpoint 2 onward).
GMAIL_MONITORING_MODE=polling
GMAIL_POLL_SECONDS=60
GMAIL_MAX_MESSAGES_PER_SYNC=100

# ---------------------------------------------------------------------------
# Outbound email (account verification, password reset, contact form) --
# backend/mail/email_client.py. Only MAIL_HOST is strictly required; if
# it's unset entirely, emails are logged to the console instead of sent
# (fine for local dev -- see email_client.py's dev-mode fallback).
#
# Works with any SMTP provider, including a Gmail app password (same setup
# as the MAILBOX_* section above, but for a "send" scope) -- or point it
# at a local test SMTP catcher like Mailpit (see docker-compose.yml),
# which needs no auth/TLS at all: set MAIL_USE_TLS=false and
# MAIL_USE_AUTH=false and leave MAIL_USERNAME/MAIL_PASSWORD unset.
# ---------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sending-account@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM_ADDRESS=your-sending-account@gmail.com
MAIL_USE_TLS=true
MAIL_USE_AUTH=true

# Used to build verification/reset links inside emails -- must be the
# real public URL of this deployment, not localhost, once deployed.
SENTINEL_PUBLIC_BASE_URL=http://localhost:5000

# Where contact-form submissions get emailed. If unset, submissions are
# still recorded in the audit log, just not emailed to anyone.
CONTACT_RECIPIENT_EMAIL=you@example.com

# Optional: error tracking (monitoring.py). Unset means completely
# disabled -- no account needed for local dev. Get a DSN from sentry.io
# (free tier available) once you're ready to monitor a real deployment.
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Log level for the web process's structured stdout logging
# (logging_config.py). One of DEBUG/INFO/WARNING/ERROR.
LOG_LEVEL=INFO
