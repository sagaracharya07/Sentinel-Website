# Copy to .env.docker (gitignored) for local `docker-compose up`.
# These are dev-only defaults matching docker-compose.yml's db/redis
# services -- fine to use as-is locally, never reuse these values anywhere
# real.

SENTINEL_ENV=development
SENTINEL_SECRET_KEY=local-docker-dev-secret-not-for-production
DATABASE_URL=postgresql://sentinel:sentinel_dev_password@db:5432/sentinel
REDIS_URL=redis://redis:6379/0

# Object storage for trained model artifacts (backend/ml/artifact_store.py)
# -- required so a retrain on the worker container reaches the web
# container, since they don't share a filesystem (same constraint Render
# has between separate services; a shared Docker volume would only mask
# it locally, not actually test it). Points at the local minio service
# below; on Render, point these at a real S3-compatible bucket instead
# (AWS S3, Cloudflare R2, Backblaze B2, etc -- any of them work, just
# leave ARTIFACT_STORE_ENDPOINT_URL unset for real AWS S3).
ARTIFACT_STORE_BUCKET=sentinel-ml-artifacts
ARTIFACT_STORE_ENDPOINT_URL=http://minio:9000
ARTIFACT_STORE_ACCESS_KEY_ID=sentinel-dev
ARTIFACT_STORE_SECRET_ACCESS_KEY=sentinel-dev-password
ARTIFACT_STORE_REGION=us-east-1

# Outbound email (account verification, password reset, contact form --
# backend/mail/email_client.py). Points at the local mailpit service,
# which needs no auth/TLS at all -- a real provider (Gmail app password,
# etc) would need MAIL_USERNAME/MAIL_PASSWORD set and both of these left
# at their real defaults (true). View "sent" mail at
# http://localhost:8025 once the stack is running.
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@sentinel.local
MAIL_USE_TLS=false
MAIL_USE_AUTH=false
SENTINEL_PUBLIC_BASE_URL=http://localhost:5000
CONTACT_RECIPIENT_EMAIL=owner@sentinel.local

# ---------------------------------------------------------------------------
# GMAIL OAUTH (primary integration) -- full setup in docs/GMAIL_SETUP.md.
# The web, worker, and beat containers all read .env.docker, so these are
# shared across all three (worker/beat need them to refresh tokens and run
# the sync). TOKEN_ENCRYPTION_KEY is REQUIRED before a mailbox can connect:
#   generate with `python crypto.py generate-key`.
# ---------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/admin/gmail/callback
GMAIL_MONITORING_MODE=polling
GMAIL_POLL_SECONDS=60
GMAIL_MAX_MESSAGES_PER_SYNC=100
GMAIL_INITIAL_LOOKBACK_DAYS=1

# Optional Gmail push (Pub/Sub). Leave blank to use polling only. When set,
# an admin can enable push from the Connected Mailboxes page.
GOOGLE_PUBSUB_TOPIC=
GOOGLE_PUBSUB_AUDIENCE=
GOOGLE_PUBSUB_VERIFICATION_TOKEN=

# .eml uploads (employee reporting). UPLOAD_DIR must be writable and OUTSIDE
# the served static tree; the default lives under backend/instance/.
EML_MAX_BYTES=5242880
# UPLOAD_DIR=/app/backend/instance/uploads

# Legacy IMAP is OFF by default (Gmail is primary). Set IMAP_ENABLED=true AND
# the MAILBOX_* values below only to use the legacy IMAP fallback instead.
IMAP_ENABLED=false
# MAILBOX_HOST=imap.gmail.com
# MAILBOX_PORT=993
# MAILBOX_USERNAME=your-test-account@gmail.com
# MAILBOX_PASSWORD=your-16-char-app-password
# MAILBOX_POLL_SECONDS=45
